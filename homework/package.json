{
    "name": "testing-api",
    "version": "2.9.0",
    "description": "testing api dengan mocha",
    "types": "module",
    "scripts": {
        "jalanin": "mocha tests --recursive --timeout 5000 --reporter spec",
        "jalanin-report-html": "mocha tests --recursive --reporter mocha-simple-html-reporter --reporter-options output=report.html",
        "jalanin-report-json": "mocha tests --recursive --reporter json > test-results.json" 
    },
    "devDependencies": {
        "mocha": "^11.7.6",
        "mocha-simple-html-reporter": "^1.0.0"
    },
    "dependencies": {
        "ajv": "^8.20.0",
        "chai": "^6.2.2",
        "node-fetch": "^3.3.2"
    }
}
